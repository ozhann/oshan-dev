---
import { site } from "../content/site";
import { fetchContributionCalendar } from "../lib/github";
import Heatmap from "../components/Heatmap.astro";
import "../styles/global.css";

const calendar = await fetchContributionCalendar(site.githubUsername);
const year = new Date().getFullYear();
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={`${site.name} — ${site.title}. ${site.tagline}`} />
    <meta name="theme-color" content="#f4f6f8" />
    <link rel="canonical" href={site.url} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;500&family=Sora:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <meta property="og:title" content={`${site.name} — ${site.title}`} />
    <meta property="og:description" content={site.tagline} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={site.url} />
    <meta property="og:image" content={`${site.url}/photo.jpg`} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={`${site.name} — ${site.title}`} />
    <meta name="twitter:description" content={site.tagline} />
    <title>{site.name} — {site.title}</title>
  </head>
  <body>
    <main class="page">
      <section class="identity" aria-label="Profile">
        <div class="photo-wrap">
          <img src={site.photo} alt={`${site.name} portrait`} width="240" height="240" />
        </div>

        <p class="location">
          <span class="online-dot" title="Available" aria-hidden="true"></span>
          {site.location}
        </p>

        <h1 class="name">{site.name}</h1>
        <p class="title">{site.title}</p>
        <p class="bio">{site.tagline}</p>
        <p class="bio">{site.bio}</p>

        <ul class="socials" aria-label="Social links">
          {
            site.socials.map((social) => (
              <li>
                <a href={social.href} target={social.href.startsWith("mailto:") ? undefined : "_blank"} rel={social.href.startsWith("mailto:") ? undefined : "noopener noreferrer"}>
                  [{social.label}]
                </a>
              </li>
            ))
          }
        </ul>
      </section>

      <section class="section" aria-labelledby="work-heading">
        <h2 id="work-heading" class="section-label">Selected work</h2>
        <ul class="project-list">
          {
            site.projects.map((project) => (
              <li>
                {project.href ? (
                  <a href={project.href} target="_blank" rel="noopener noreferrer">
                    <span class="project-name">{project.name}</span>
                    <span class="project-meta">
                      {project.role} · {project.industry}
                    </span>
                  </a>
                ) : (
                  <div class="project-static">
                    <span class="project-name">{project.name}</span>
                    <span class="project-meta">
                      {project.role} · {project.industry}
                    </span>
                  </div>
                )}
              </li>
            ))
          }
        </ul>
      </section>

      <section class="section" aria-labelledby="activity-heading">
        <h2 id="activity-heading" class="section-label">Activity</h2>
        <Heatmap calendar={calendar} username={site.githubUsername} />
      </section>

      <footer class="footer">
        <p>© {year} {site.name}</p>
      </footer>
    </main>
  </body>
</html>
