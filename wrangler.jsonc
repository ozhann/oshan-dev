{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "ozhan-xyz",
  "compatibility_date": "2026-07-12",
  "assets": {
    "directory": "./dist",
    "not_found_handling": "404-page"
  },
  "routes": [
    {
      "pattern": "ozhan.xyz",
      "custom_domain": true
    },
    {
      "pattern": "www.ozhan.xyz",
      "custom_domain": true
    }
  ]
}
